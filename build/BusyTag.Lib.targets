<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Copy bundled esptool executables to the consuming project's output directory -->
  <Target Name="CopyBusyTagEspTools" AfterTargets="Build">
    <PropertyGroup>
      <BusyTagToolsSource>$(MSBuildThisFileDirectory)..\tools\</BusyTagToolsSource>
    </PropertyGroup>

    <ItemGroup>
      <BusyTagEspToolFiles Include="$(BusyTagToolsSource)**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(BusyTagEspToolFiles)"
          DestinationFiles="@(BusyTagEspToolFiles->'$(OutputPath)Tools\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <!-- Set execute permission on Unix -->
    <Exec Command="chmod +x '$(OutputPath)Tools/macos/esptool' '$(OutputPath)Tools/linux/esptool'"
          Condition="'$(OS)' != 'Windows_NT'"
          IgnoreExitCode="true" />
  </Target>

  <!-- Copy native macOS USB driver to output -->
  <Target Name="CopyBusyTagNativeDriver" AfterTargets="Build" Condition="'$(OS)' != 'Windows_NT'">
    <PropertyGroup>
      <BusyTagNativeSource>$(MSBuildThisFileDirectory)..\runtimes\osx\native\</BusyTagNativeSource>
    </PropertyGroup>
    <Copy SourceFiles="$(BusyTagNativeSource)libBusyTagUSBDriver.dylib"
          DestinationFolder="$(OutputPath)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(BusyTagNativeSource)libBusyTagUSBDriver.dylib')" />
  </Target>

  <Target Name="CopyBusyTagNativeDriverPublish" AfterTargets="Publish" Condition="'$(OS)' != 'Windows_NT'">
    <PropertyGroup>
      <BusyTagNativeSource>$(MSBuildThisFileDirectory)..\runtimes\osx\native\</BusyTagNativeSource>
    </PropertyGroup>
    <Copy SourceFiles="$(BusyTagNativeSource)libBusyTagUSBDriver.dylib"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(BusyTagNativeSource)libBusyTagUSBDriver.dylib')" />
  </Target>

  <!-- Also copy on Publish -->
  <Target Name="CopyBusyTagEspToolsPublish" AfterTargets="Publish">
    <PropertyGroup>
      <BusyTagToolsSource>$(MSBuildThisFileDirectory)..\tools\</BusyTagToolsSource>
    </PropertyGroup>

    <ItemGroup>
      <BusyTagEspToolFilesPublish Include="$(BusyTagToolsSource)**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(BusyTagEspToolFilesPublish)"
          DestinationFiles="@(BusyTagEspToolFilesPublish->'$(PublishDir)Tools\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

    <!-- Set execute permission on Unix -->
    <Exec Command="chmod +x '$(PublishDir)Tools/macos/esptool' '$(PublishDir)Tools/linux/esptool'"
          Condition="'$(OS)' != 'Windows_NT'"
          IgnoreExitCode="true" />
  </Target>

</Project>
